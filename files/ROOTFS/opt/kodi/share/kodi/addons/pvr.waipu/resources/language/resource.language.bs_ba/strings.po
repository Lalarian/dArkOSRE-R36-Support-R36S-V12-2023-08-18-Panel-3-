msgctxt "#30050"
msgid "Provider/Authentication: Using Waipu (Device Login) or O2 TV is recommended! Do not use credentials login."
msgstr "Pružatelj usluga/Autentifikacija: Preporučuje se korištenje Waipu-a (prijava na uređaj) ili O2 TV-a! Nemojte koristiti prijavu s vjerodajnicama."

msgctxt "#30051"
msgid "Widevine CDM is required to play non public channels. Click to install Widevine CDM if some channels are not working!"
msgstr "Za reprodukciju kanala koji nisu javni potreban je Widevine CDM. Kliknite da instalirate Widevine CDM ako neki kanali ne rade!"

msgctxt "#30052"
msgid "Check whether Widevine CDM is installed. Required to play non public channels."
msgstr "Provjerite da li je instaliran Widevine CDM. Potreban je za reprodukciju kanala koji nisu javni."

msgctxt "#30053"
msgid "Select streaming protocol. Use AUTO or MPEG_DASH. Do not use HLS, because not all channels support this."
msgstr "Odaberite protokol za streaming. Koristite AUTO ili MPEG_DASH. Nemojte koristiti HLS, jer ga ne podržavaju svi kanali."

msgctxt "#30054"
msgid "By default, inputstream.adaptive is used for playing HLS. Check this option to use inputstream.ffmpegdirect instead."
msgstr "Podrazumevano, inputstream.adaptive se koristi za reprodukciju HLS-a. Označite ovu opciju da biste umjesto toga koristili inputstream.ffmpegdirect."


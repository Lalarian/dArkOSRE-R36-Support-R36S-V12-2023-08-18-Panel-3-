msgstr "HLS: Använd inputstream.ffmpegdirect"

msgctxt "#30050"
msgid "Provider/Authentication: Using Waipu (Device Login) or O2 TV is recommended! Do not use credentials login."
msgstr "Leverantör/Autentisering: Vi rekommenderar att du använder Waipu (enhetsinloggning) eller O2 TV! Använd inte inloggning med lösenord."

msgctxt "#30051"
msgid "Widevine CDM is required to play non public channels. Click to install Widevine CDM if some channels are not working!"
msgstr "Widevine CDM krävs för att spela upp icke-offentliga kanaler. Klicka för att installera Widevine CDM om vissa kanaler inte fungerar!"

msgctxt "#30052"
msgid "Check whether Widevine CDM is installed. Required to play non public channels."
msgstr "Kontrollera om Widevine CDM är installerat. Krävs för att spela upp icke-offentliga kanaler."

msgctxt "#30053"
msgid "Select streaming protocol. Use AUTO or MPEG_DASH. Do not use HLS, because not all channels support this."
msgstr "Välj strömningsprotokoll. Använd AUTO eller MPEG_DASH. Använd inte HLS, eftersom inte alla kanaler stöder detta."

msgctxt "#30054"
msgid "By default, inputstream.adaptive is used for playing HLS. Check this option to use inputstream.ffmpegdirect instead."
msgstr "Som standard används inputstream.adaptive för uppspelning av HLS. Markera det här alternativet för att använda inputstream.ffmpegdirect istället."

msgctxt "#30055"
msgid "Recordings: Load description and year"
msgstr "Inspelningar: Läs in beskrivning och år"

msgctxt "#30500"
msgid "Inputstream error"
msgstr "Fel i Inputstream"

